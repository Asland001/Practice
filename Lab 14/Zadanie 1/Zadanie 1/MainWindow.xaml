<Window x:Class="CinemaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CinemaApp"
        Title="Бронирование билетов" Height="400" Width="600">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Список сеансов -->
        <ListBox ItemsSource="{Binding Sessions}"
                 SelectedItem="{Binding SelectedSession}"
                 Grid.Row="0">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="5">
                        <StackPanel>
                            <TextBlock Text="{Binding MovieName}" 
                                       FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="{Binding Time}"/>
                            <TextBlock>
                                <Run Text="Свободные места: "/>
                                <Run Text="{Binding AvailableSeats}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

        <!-- Выбранный фильм -->
        <StackPanel Grid.Row="1" Margin="0,10">
            <TextBlock Text="Выбранный фильм:" FontWeight="Bold"/>
            <TextBlock Text="{Binding SelectedSession.MovieName}"/>
        </StackPanel>

        <!-- Управление -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10">
            <TextBlock Text="Количество билетов:" VerticalAlignment="Center"/>
            <TextBox Width="50" Margin="10,0"
                     Text="{Binding TicketCount, Mode=TwoWay}"/>

            <Button Content="Купить билет"
                    Margin="10,0"
                    Click="BuyButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="DarkBlue"
                                CornerRadius="10"
                                Padding="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="White"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
        
        

    </Grid>
</Window>