<Window x:Class="CinemaApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CinemaApp.ViewModels"
        Title="Кинотеатр — Система бронирования" 
        Height="450" Width="700"
        MinWidth="600" MinHeight="400">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding BookTicketCommand}"/>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding EditTicketCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding CancelTicketCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл"/>
            <MenuItem Header="Фильмы"/>
            <MenuItem Header="Залы"/>
            <MenuItem Header="Настройки"/>
        </Menu>

        <!-- Toolbar -->
        <ToolBar DockPanel.Dock="Top">
            <Button Content="Забронировать" Command="{Binding BookTicketCommand}"/>
            <Button Content="Изменить бронь" Command="{Binding EditTicketCommand}"/>
            <Button Content="Отменить бронь" Command="{Binding CancelTicketCommand}"/>
        </ToolBar>

        <!-- Основной контент -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <TextBlock Text="Система бронирования кинотеатра"
                       FontSize="24" FontWeight="SemiBold"
                       Margin="0,0,0,30"
                       HorizontalAlignment="Center"/>

            <Button Content="Забронировать билет" 
                    Width="280" Height="45" Margin="10"
                    FontSize="14"
                    Command="{Binding BookTicketCommand}"/>

            <Button Content="Изменить бронь" 
                    Width="280" Height="45" Margin="10"
                    FontSize="14"
                    Command="{Binding EditTicketCommand}"/>

            <Button Content="Отменить бронь" 
                    Width="280" Height="45" Margin="10"
                    FontSize="14"
                    Command="{Binding CancelTicketCommand}"/>
        </StackPanel>
    </DockPanel>
</Window>