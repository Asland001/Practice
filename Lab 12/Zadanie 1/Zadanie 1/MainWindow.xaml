<Window x:Class="CinemaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Кинотеатр" Height="450" Width="600">

    <StackPanel Margin="10">

        <!-- Заголовок -->
        <TextBlock Text="Кинотеатр"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,10"/>

        <!-- Выбор фильма -->
        <ComboBox x:Name="MovieComboBox"
                  Height="30"
                  Margin="0,0,0,10"/>

        <!-- Сетка мест -->
        <Grid x:Name="SeatsGrid"
              Margin="0,0,0,10"/>

        <!-- Кнопка -->
        <Button Content="Забронировать"
                Height="40"
                Click="BookSeats_Click"/>

    </StackPanel>
</Window>